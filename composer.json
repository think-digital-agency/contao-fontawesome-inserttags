    "homepage": "https://github.com/think-digital-agency/contao-font-awesome-insert-tags",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Think Digital Agency",
            "homepage": "https://think-digital.agency"
        }
    ],
    "require": {
        "php": "^8.2",
        "contao/core-bundle": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "ThinkDigital\\ContaoFontAwesomeInsertTags\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "ThinkDigital\\ContaoFontAwesomeInsertTags\\ContaoManager\\Plugin"
